generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// En bruker / deltaker i Trivselslekene
model User {
  id           String   @id @default(cuid())
  navn         String   @unique
  epost        String?  @unique
  passordHash  String?
  bildeUrl     String?
  createdAt    DateTime @default(now())

  vertFor          Ovelse[]          @relation("Vert")
  individuelleResultater ResultatIndividuell[]
  lagmedlemskap    LagMedlem[]
  turneringsDeltagelser TurneringsDeltager[]
}

/// Et årgang av Trivselslekene, f.eks. "Trivselslekene 2026"
model Sesong {
  id        String   @id @default(cuid())
  aar       Int      @unique
  navn      String
  aktiv     Boolean  @default(true)
  createdAt DateTime @default(now())

  ovelser     Ovelse[]
  turneringer Turnering[]
}

enum OvelseType {
  INDIVIDUELL
  LAG
}

enum LagFormat {
  PAR
  TRIO
  FIRE_MOT_FIRE
  FEM_MOT_FEM
  FIRE_MOT_FEM
  TRE_MOT_TRE_MOT_TRE
  TO_MOT_TO_MOT_TO_MOT_TO
  TO_LAG
  TRE_LAG
  FIRE_LAG
  FLERE_LAG
  ANNET
}

enum OvelseStatus {
  PLANLAGT
  PAAGAAR
  FULLFORT
}

/// Egenskaper en lek tester. En lek kan ha én eller flere.
enum Kvalitet {
  STYRKE
  UTHOLDENHET
  PRESISJON
  FLAKS
  LAGSPILL
  TAKTIKK
  HURTIGHET
  KREATIVITET
  KUNNSKAP
  NERVER
}

/// En øvelse ("game") i lekene. Verten arrangerer øvelsen. Normalt deltar ikke
/// verten selv, men en "felles lek" er en foreslått lek der alle er med.
model Ovelse {
  id          String       @id @default(cuid())
  navn        String
  beskrivelse String?
  lokasjon    String?
  type        OvelseType
  lagFormat   LagFormat?
  kvaliteter  Kvalitet[]
  fellesLek   Boolean      @default(false)
  bildeUrl    String?      /// Data-URL for kart/illustrasjon til øvelsen (brukes som fallback hvis ingen faser)
  status      OvelseStatus @default(PLANLAGT)
  aktivFase   Int          @default(0) /// 0 = ingen aktiv fase; 1..N = fasenummer
  createdAt   DateTime     @default(now())

  sesongId String
  sesong   Sesong @relation(fields: [sesongId], references: [id], onDelete: Cascade)

  vertId String
  vert   User   @relation("Vert", fields: [vertId], references: [id])

  lag                    Lag[]
  individuelleResultater ResultatIndividuell[]
  lagResultater          ResultatLag[]
  faser                  OvelseFase[]
}

/// En fase i en øvelse med flere deler. Hver fase kan ha eget bilde/kart
/// og tittel. Verten navigerer mellom faser under gjennomføring.
model OvelseFase {
  id         String @id @default(cuid())
  ovelseId   String
  ovelse     Ovelse @relation(fields: [ovelseId], references: [id], onDelete: Cascade)
  rekkefolge Int    /// 1, 2, 3, ...
  tittel     String? /// Valgfri tittel for fasen (f.eks. "Hele hagen")
  bildeUrl   String? /// Data-URL for denne fasens kart/illustrasjon

  @@unique([ovelseId, rekkefolge])
}

/// Et lag i en lag-øvelse (par, trio eller flere-lag-format som bridge/fotball)
model Lag {
  id       String @id @default(cuid())
  navn     String
  ovelseId String
  ovelse   Ovelse @relation(fields: [ovelseId], references: [id], onDelete: Cascade)

  medlemmer LagMedlem[]
  resultat  ResultatLag?
}

model LagMedlem {
  id     String @id @default(cuid())
  lagId  String
  lag    Lag    @relation(fields: [lagId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([lagId, userId])
  @@index([lagId])
  @@index([userId])
}

/// Resultat for en enkeltperson i en individuell øvelse
model ResultatIndividuell {
  id        String  @id @default(cuid())
  ovelseId  String
  ovelse    Ovelse  @relation(fields: [ovelseId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  plassering Int?
  poeng     Float
  notat     String?

  @@unique([ovelseId, userId])
  @@index([ovelseId])
  @@index([userId])
}

/// Resultat for et lag i en lag-øvelse. Poeng krediteres alle lagmedlemmer.
model ResultatLag {
  id        String @id @default(cuid())
  ovelseId  String
  ovelse    Ovelse @relation(fields: [ovelseId], references: [id], onDelete: Cascade)
  lagId     String @unique
  lag       Lag    @relation(fields: [lagId], references: [id], onDelete: Cascade)
  plassering Int?
  poeng     Float
  notat     String?

  @@unique([ovelseId, lagId])
  @@index([ovelseId])
}

/// En turnering med dobbel-eliminering (winners + losers bracket)
model Turnering {
  id        String   @id @default(cuid())
  navn      String
  sesongId  String
  sesong    Sesong   @relation(fields: [sesongId], references: [id], onDelete: Cascade)
  status    String   @default("PLANLAGT") // PLANLAGT | PAAGAAR | FULLFORT
  createdAt DateTime @default(now())

  deltagere TurneringsDeltager[]
  kamper    TurneringsKamp[]
}

/// Deltager i en turnering med seed 1–8
model TurneringsDeltager {
  id          String @id @default(cuid())
  turneringId String
  turnering   Turnering @relation(fields: [turneringId], references: [id], onDelete: Cascade)
  userId      String
  user        User   @relation(fields: [userId], references: [id])
  seed        Int

  kamperSomDeltager1 TurneringsKamp[] @relation("Deltager1")
  kamperSomDeltager2 TurneringsKamp[] @relation("Deltager2")
  seire             TurneringsKamp[] @relation("Vinner")

  @@unique([turneringId, userId])
  @@unique([turneringId, seed])
}

/// En kamp i turnerings-bracket
model TurneringsKamp {
  id          String @id @default(cuid())
  turneringId String
  turnering   Turnering @relation(fields: [turneringId], references: [id], onDelete: Cascade)

  runde       Int    // rundenummer (1–5 i winners, 1–5 i losers)
  bracket     String // "W" = winners, "L" = losers, "G" = grand finals
  posisjon    Int    // posisjon innen runden (1..N)

  deltager1Id String?
  deltager1   TurneringsDeltager? @relation("Deltager1", fields: [deltager1Id], references: [id])
  deltager2Id String?
  deltager2   TurneringsDeltager? @relation("Deltager2", fields: [deltager2Id], references: [id])
  vinnerId    String?
  vinner      TurneringsDeltager? @relation("Vinner", fields: [vinnerId], references: [id])

  status      String   @default("VENTER") // VENTER | KLAR | FULLFORT

  @@unique([turneringId, bracket, runde, posisjon])
  @@index([turneringId])
}
